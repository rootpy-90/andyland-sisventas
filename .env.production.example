# ============================================
# Andyland SisVentas - Variables de Entorno para Producción
# ============================================
# Copiar este archivo a .env y completar los valores
# cp .env.production.example .env

# ============================================
# Configuración de la Aplicación
# ============================================
APP_NAME="Andyland SisVentas"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://andyland-sisventas.ndeapp.com

# ============================================
# Configuración de Base de Datos
# ============================================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=dbventaslaravel
DB_USERNAME=sisventas
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ============================================
# Configuración de Cache y Session
# ============================================
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync

# ============================================
# Configuración de Mail (Opcional)
# ============================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

# ============================================
# Configuración de Logging
# ============================================
LOG_CHANNEL=daily
LOG_LEVEL=error
